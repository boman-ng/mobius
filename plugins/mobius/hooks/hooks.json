{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/mobius\" hook session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Shell|exec_command|write_stdin|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/mobius\" hook pre-tool-use",
            "timeout": 10,
            "statusMessage": "Checking the Mobius Core state boundary"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/mobius\" hook stop",
            "timeout": 10,
            "statusMessage": "Checking the Mobius Objective completion claim"
          }
        ]
      }
    ]
  }
}
